{
    "name": "@secsuite/typescript-sdk",
    "version": "0.0.11",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/secsuite/typescript-sdk.git"
    },
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./index": {
            "import": {
                "types": "./dist/esm/api/resources/index/exports.d.mts",
                "default": "./dist/esm/api/resources/index/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/index/exports.d.ts",
                "default": "./dist/cjs/api/resources/index/exports.js"
            },
            "default": "./dist/cjs/api/resources/index/exports.js"
        },
        "./documentation": {
            "import": {
                "types": "./dist/esm/api/resources/documentation/exports.d.mts",
                "default": "./dist/esm/api/resources/documentation/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/documentation/exports.d.ts",
                "default": "./dist/cjs/api/resources/documentation/exports.js"
            },
            "default": "./dist/cjs/api/resources/documentation/exports.js"
        },
        "./config": {
            "import": {
                "types": "./dist/esm/api/resources/config/exports.d.mts",
                "default": "./dist/esm/api/resources/config/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/config/exports.d.ts",
                "default": "./dist/cjs/api/resources/config/exports.js"
            },
            "default": "./dist/cjs/api/resources/config/exports.js"
        },
        "./updater": {
            "import": {
                "types": "./dist/esm/api/resources/updater/exports.d.mts",
                "default": "./dist/esm/api/resources/updater/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/updater/exports.d.ts",
                "default": "./dist/cjs/api/resources/updater/exports.js"
            },
            "default": "./dist/cjs/api/resources/updater/exports.js"
        },
        "./desktopAuth": {
            "import": {
                "types": "./dist/esm/api/resources/desktopAuth/exports.d.mts",
                "default": "./dist/esm/api/resources/desktopAuth/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/desktopAuth/exports.d.ts",
                "default": "./dist/cjs/api/resources/desktopAuth/exports.js"
            },
            "default": "./dist/cjs/api/resources/desktopAuth/exports.js"
        },
        "./gateway": {
            "import": {
                "types": "./dist/esm/api/resources/gateway/exports.d.mts",
                "default": "./dist/esm/api/resources/gateway/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/gateway/exports.d.ts",
                "default": "./dist/cjs/api/resources/gateway/exports.js"
            },
            "default": "./dist/cjs/api/resources/gateway/exports.js"
        },
        "./history": {
            "import": {
                "types": "./dist/esm/api/resources/history/exports.d.mts",
                "default": "./dist/esm/api/resources/history/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/history/exports.d.ts",
                "default": "./dist/cjs/api/resources/history/exports.js"
            },
            "default": "./dist/cjs/api/resources/history/exports.js"
        },
        "./settings": {
            "import": {
                "types": "./dist/esm/api/resources/settings/exports.d.mts",
                "default": "./dist/esm/api/resources/settings/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/settings/exports.d.ts",
                "default": "./dist/cjs/api/resources/settings/exports.js"
            },
            "default": "./dist/cjs/api/resources/settings/exports.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {},
    "devDependencies": {
        "webpack": "^5.105.4",
        "ts-loader": "^9.5.4",
        "vitest": "^4.1.1",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.9.3",
        "@biomejs/biome": "2.4.10"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
